{
  "name": "aiagent-sdk",
  "version": "1.0.0",
  "description": "AI Agent 前端 SDK — UMD 脚本标签 + ESM/React 适配",
  "type": "module",
  "main": "./dist/ai-agent-sdk.umd.js",
  "module": "./dist/ai-agent-sdk.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ai-agent-sdk.esm.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.esm.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "build:esm": "tsc --noEmit && vite build",
    "build:umd": "vite build --config vite.config.umd.ts",
    "build": "npm run build:esm && npm run build:umd",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "dompurify": "^3.1.6",
    "marked": "^13.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0"
  }
}
